// #package uispecs

// #section MainDialog

{
  "type": "sidebar",
  "bind": "sidebar",
  "children": [
    {
      "type": "tabs",
      "children": {
        "Settings": {
          "type": "panel",
          "children": [
            {
              "type": "accordion",
              "label": "Renderer",
              "children": [
                {
                  "type": "field",
                  "label": "Renderer:",
                  "children": [
                    {
                      "type": "dropdown",
                      "bind": "rendererSelect",
                      "options": [
                        {
                          "value": "mip",
                          "label": "Maximum intensity projection"
                        },
                        {
                          "value": "iso",
                          "label": "Isosurface extraction"
                        },
                        {
                          "value": "eam",
                          "label": "Emission-absorption model"
                        },
                        {
                          "value": "mcs",
                          "label": "Single scattering"
                        },
                        {
                          "value": "mcm",
                          "label": "Multiple scattering",
                          "selected": true
                        },
                        {
                          "value": "mcc",
                          "label": "Multiple scattering (compute)"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "panel",
                  "bind": "rendererSettingsContainer"
                }
              ]
            }
          ]
        }
      }
    }
  ]
}